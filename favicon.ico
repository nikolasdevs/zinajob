<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="64" height="64">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0f3460;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0A2540;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Background: navy rounded square -->
  <rect width="64" height="64" rx="13" fill="url(#bgGrad)"/>

  <!-- Subtle inner glow top edge -->
  <rect width="64" height="1.5" rx="0" fill="rgba(255,255,255,0.06)"/>

  <!-- Z mark — white: top bar + diagonal -->
  <path d="M 12 17 L 52 17 L 12 47"
    stroke="white"
    stroke-width="7"
    stroke-linecap="round"
    stroke-linejoin="round"
    fill="none"/>

  <!-- Z mark — green: bottom bar -->
  <path d="M 12 47 L 52 47"
    stroke="#00C896"
    stroke-width="7"
    stroke-linecap="round"
    fill="none"/>

  <!-- Green accent dot: top-right corner of Z -->
  <circle cx="52" cy="17" r="4.5" fill="#00C896"/>
</svg>
